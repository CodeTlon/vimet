{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm start)",
      "Bash(npm install*)",
      "Bash(npm ci)",
      "Bash(npx playwright*)",
      "Bash(npx supabase*)",
      "Bash(npx tsx*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git pull*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'RECORDATORIO: Actualizar .claude/CLAUDE.md — si hubo cambios estructurales (archivos nuevos, tablas, env vars, quirks, URL producción), editar la sección correspondiente y agregar fila en Historial de Cambios.'"
          }
        ]
      }
    ]
  }
}
